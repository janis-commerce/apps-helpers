{
	"name": "@janiscommerce/apps-helpers",
	"version": "1.5.0",
	"description": "Helpers for janis apps",
	"main": "dist/index.umd.js",
	"type": "module",
	"directories": {
		"lib": "lib",
		"test": "tests"
	},
	"scripts": {
		"test": "export TEST_ENV=true; mocha --exit -R nyan --recursive tests/",
		"build-docs": "jsdoc2md --template template-readme.hbs --configure ./jsdoc2md.json --files lib/*.js > README.md",
		"test-ci": "c8 --reporter=lcov --reporter=text-summary mocha --exit --recursive tests/",
		"build": "rm -rf dist && rollup -c rollup/rollup.config.mjs",
		"coverage": "nyc npm test",
		"lint": "eslint lib/ tests/",
		"build-types": "tsc lib/index.js --declaration --allowJs --emitDeclarationOnly --outDir types",
		"prepare": "husky install"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/janis-commerce/apps-helper.git"
	},
	"files": [
		"dist/",
		"types/"
	],
	"types": "types/index.d.ts",
	"keywords": [
		"janis",
		"apps",
		"janiscommerce"
	],
	"author": "Janis",
	"license": "ISC",
	"bugs": {
		"url": "https://github.com/janis-commerce/apps-helper/issues"
	},
	"homepage": "https://github.com/janis-commerce/apps-helper#readme",
	"devDependencies": {
		"@babel/core": "^7.21.3",
		"@babel/eslint-parser": "^7.21.3",
		"@babel/eslint-plugin": "^7.19.1",
		"@babel/plugin-proposal-class-properties": "^7.18.6",
		"@babel/plugin-proposal-object-rest-spread": "^7.20.7",
		"@babel/preset-env": "^7.20.2",
		"@rollup/plugin-babel": "^6.0.2",
		"@rollup/plugin-commonjs": "^23.0.2",
		"@rollup/plugin-node-resolve": "^15.0.1",
		"@typescript-eslint/eslint-plugin": "^5.54.1",
		"c8": "^7.13.0",
		"eslint": "^8.35.0",
		"eslint-config-airbnb-base": "^15.0.0",
		"eslint-config-prettier": "^8.7.0",
		"eslint-config-standard-with-typescript": "^34.0.0",
		"eslint-plugin-import": "^2.27.5",
		"eslint-plugin-n": "^15.6.1",
		"eslint-plugin-prettier": "^4.2.1",
		"eslint-plugin-promise": "^6.1.1",
		"fs": "^0.0.1-security",
		"https": "^1.0.0",
		"husky": "^8.0.0",
		"jsdoc-babel": "^0.5.0",
		"jsdoc-to-markdown": "^8.0.0",
		"mocha": "^10.2.0",
		"path": "^0.12.7",
		"prettier": "^2.8.4",
		"rollup": "^3.4.0",
		"sinon": "^15.0.1",
		"typescript": "^5.0.4",
		"util": "^0.12.5"
	}
}
