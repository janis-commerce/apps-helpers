 {
  "env": {
    "node": true,
    "es6": true,
    "mocha": true
  },
  "parser": "@babel/eslint-parser",
  "extends": "airbnb-base",
  "overrides": [
  ],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "import/extensions": ["error", "ignorePackages", { "": "never" }]
  }
}
